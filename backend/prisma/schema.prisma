// -------------------------------------------------------
// AOP Platform — Prisma Schema (Redesigned v2)
// -------------------------------------------------------

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// -------------------------------------------------------
// Identity & Access
// -------------------------------------------------------

model Role {
  id   String @id @default(uuid())
  name String @unique

  users User[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model Team {
  id   String @id @default(uuid())
  name String

  users    User[]
  projects Project[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("teams")
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String  @map("password_hash")
  firstName    String? @map("first_name")
  lastName     String? @map("last_name")
  isActive     Boolean @default(true) @map("is_active")

  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id])

  teamId String? @map("team_id")
  team   Team?   @relation(fields: [teamId], references: [id])

  organizations UserOrganization[]

  discoveredProjects     Project[] @relation("ProjectDiscoveredBy")
  lastEditedProjects     Project[] @relation("ProjectLastEditedBy")
  assignedAsCloser       Project[] @relation("ProjectCloser")
  assignedAsPM           Project[] @relation("ProjectPM")
  reviewedProjects       Project[] @relation("ProjectReviewer")
  scriptReviewedProjects Project[] @relation("ProjectScriptReviewer")

  assignedTasks Task[]         @relation("TaskAssignee")
  qaReviews     QAReview[]     @relation("QAReviewer")
  eventsActed   Event[]        @relation("EventActor")
  refreshTokens RefreshToken[]
  meetings      Meeting[]      @relation("MeetingCloser")
  syncedChats       ChatMessage[]  @relation("ChatSyncedBy")
  addedProjectLinks ProjectLink[]  @relation("ProjectLinkAddedBy")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([email], map: "idx_users_email")
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([token], map: "idx_refresh_tokens_token")
  @@map("refresh_tokens")
}

// -------------------------------------------------------
// Organizations (Multi-tenant)
// -------------------------------------------------------

model Organization {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?
  isActive    Boolean @default(true) @map("is_active")

  members  UserOrganization[]
  niches   Niche[]
  projects Project[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("organizations")
}

model UserOrganization {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, organizationId])
  @@index([userId], map: "idx_user_organizations_user")
  @@index([organizationId], map: "idx_user_organizations_org")
  @@map("user_organizations")
}

// -------------------------------------------------------
// Niches (Org-scoped Project Categories)
// -------------------------------------------------------

model Niche {
  id          String  @id @default(uuid())
  name        String
  slug        String
  description String?
  isActive    Boolean @default(true) @map("is_active")

  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  projects Project[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([slug, organizationId])
  @@map("niches")
}

// -------------------------------------------------------
// Projects (Full Pipeline — Core Entity)
// -------------------------------------------------------

enum ProjectStage {
  DISCOVERED
  SCRIPTED
  SCRIPT_REVIEW
  VIDEO_DRAFT
  UNDER_REVIEW
  ASSIGNED
  BID_SUBMITTED
  VIEWED
  MESSAGED
  INTERVIEW
  WON
  IN_PROGRESS
  COMPLETED
  LOST
  CANCELLED
}

enum PricingType {
  HOURLY
  FIXED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model Project {
  id String @id @default(uuid())

  // Job Discovery Fields
  title          String
  jobUrl         String?     @map("job_url")
  jobDescription String?     @map("job_description")
  pricingType    PricingType @map("pricing_type")
  hourlyRateMin  Float?      @map("hourly_rate_min")
  hourlyRateMax  Float?      @map("hourly_rate_max")
  fixedPrice     Float?      @map("fixed_price")

  // Pipeline Stage
  stage     ProjectStage @default(DISCOVERED)
  sortOrder Float        @default(0) @map("sort_order")

  // Script / Bid Materials
  coverLetter    String?   @map("cover_letter")
  videoScript    String?   @map("video_script")
  upworkAccount  String?   @map("upwork_account")
  bidAmount      Float?    @map("bid_amount")
  bidSubmittedAt DateTime? @map("bid_submitted_at")

  // Script Review (Lead -> Bidder)
  scriptReviewStatus   ReviewStatus? @map("script_review_status")
  scriptReviewComments String?       @map("script_review_comments")
  scriptReviewedById   String?       @map("script_reviewed_by_id")
  scriptReviewedBy     User?         @relation("ProjectScriptReviewer", fields: [scriptReviewedById], references: [id])
  scriptReviewedAt     DateTime?     @map("script_reviewed_at")

  // Video Review (Lead -> Closer)
  reviewStatus   ReviewStatus? @map("review_status")
  reviewComments String?       @map("review_comments")
  reviewedById   String?       @map("reviewed_by_id")
  reviewedBy     User?         @relation("ProjectReviewer", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?     @map("reviewed_at")

  // Org Scoping
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])

  nicheId String? @map("niche_id")
  niche   Niche?  @relation(fields: [nicheId], references: [id])

  teamId String? @map("team_id")
  team   Team?   @relation(fields: [teamId], references: [id])

  // Assignments
  discoveredById String? @map("discovered_by_id")
  discoveredBy   User?   @relation("ProjectDiscoveredBy", fields: [discoveredById], references: [id])

  lastEditedById String? @map("last_edited_by_id")
  lastEditedBy   User?   @relation("ProjectLastEditedBy", fields: [lastEditedById], references: [id])

  assignedCloserId String? @map("assigned_closer_id")
  assignedCloser   User?   @relation("ProjectCloser", fields: [assignedCloserId], references: [id])

  assignedPMId String? @map("assigned_pm_id")
  assignedPM   User?   @relation("ProjectPM", fields: [assignedPMId], references: [id])

  // Won Project Fields
  clientName       String?   @map("client_name")
  clientNotes      String?   @map("client_notes")
  contractValue    Float?    @map("contract_value")
  contractCurrency String    @default("USD") @map("contract_currency")
  startDate        DateTime? @map("start_date")
  endDate          DateTime? @map("end_date")

  milestones            Milestone[]
  tasks                 Task[]
  meetings              Meeting[]
  videoProposals        VideoProposal[]
  chatMessages          ChatMessage[]
  links                 ProjectLink[]
  experimentAssignments ExperimentAssignment[]

  // Extension metadata
  importedFromExtension Boolean @default(false) @map("imported_from_extension")
  upworkSkills          String[] @map("upwork_skills")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([stage], map: "idx_projects_stage")
  @@index([organizationId], map: "idx_projects_org")
  @@index([nicheId], map: "idx_projects_niche")
  @@index([teamId], map: "idx_projects_team")
  @@index([assignedCloserId], map: "idx_projects_closer")
  @@index([assignedPMId], map: "idx_projects_pm")
  @@index([discoveredById], map: "idx_projects_discovered_by")
  @@index([reviewedById], map: "idx_projects_reviewed_by")
  @@map("projects")
}

model Milestone {
  id        String  @id @default(uuid())
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name      String
  dueDate   DateTime? @map("due_date")
  amount    Float?
  completed Boolean   @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("milestones")
}

// -------------------------------------------------------
// Video Proposals (attached to Project)
// -------------------------------------------------------

model VideoProposal {
  id        String  @id @default(uuid())
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  videoUrl   String  @map("video_url")
  storageKey String  @map("storage_key")
  duration   Int?
  fileSize   Int?    @map("file_size")
  mimeType   String? @map("mime_type")

  thumbnailUrl String? @map("thumbnail_url")
  viewCount    Int     @default(0) @map("view_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("video_proposals")
}

// -------------------------------------------------------
// Meetings (attached to Project — lightweight links)
// -------------------------------------------------------

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum MeetingType {
  INTERVIEW
  CLIENT_CHECKIN
}

model Meeting {
  id        String  @id @default(uuid())
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  closerId String? @map("closer_id")
  closer   User?   @relation("MeetingCloser", fields: [closerId], references: [id])

  type        MeetingType   @default(INTERVIEW)
  scheduledAt DateTime      @map("scheduled_at")
  completedAt DateTime?     @map("completed_at")
  status      MeetingStatus @default(SCHEDULED)
  notes       String?

  meetingUrl String? @map("meeting_url")
  fathomUrl  String? @map("fathom_url")
  loomUrl    String? @map("loom_url")
  driveUrl   String? @map("drive_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId], map: "idx_meetings_project")
  @@map("meetings")
}

// -------------------------------------------------------
// Tasks (PM creates for Operators)
// -------------------------------------------------------

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
}

model Task {
  id        String  @id @default(uuid())
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId String? @map("assignee_id")
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  title          String
  description    String?
  status         TaskStatus @default(TODO)
  priority       Int        @default(0)
  estimatedHours Float?     @map("estimated_hours")
  completedAt    DateTime?  @map("completed_at")

  qaReview QAReview?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId], map: "idx_tasks_project")
  @@index([assigneeId], map: "idx_tasks_assignee")
  @@index([status], map: "idx_tasks_status")
  @@map("tasks")
}

// -------------------------------------------------------
// QA Reviews
// -------------------------------------------------------

enum QAStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_CHANGES
}

model QAReview {
  id     String @id @default(uuid())
  taskId String @unique @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  reviewerId String @map("reviewer_id")
  reviewer   User   @relation("QAReviewer", fields: [reviewerId], references: [id])

  status   QAStatus @default(PENDING)
  score    Int?
  comments String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("qa_reviews")
}

// -------------------------------------------------------
// Project Links (GitHub, Vercel, Staging, etc.)
// -------------------------------------------------------

enum ProjectLinkType {
  GITHUB
  VERCEL
  STAGING
  DOCS
  OTHER
}

model ProjectLink {
  id        String          @id @default(uuid())
  projectId String          @map("project_id")
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  label String
  url   String
  type  ProjectLinkType @default(OTHER)

  addedById String? @map("added_by_id")
  addedBy   User?   @relation("ProjectLinkAddedBy", fields: [addedById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId], map: "idx_project_links_project")
  @@map("project_links")
}

// -------------------------------------------------------
// Chat Messages (Synced from Upwork via Extension)
// -------------------------------------------------------

enum ChatSenderType {
  CLIENT
  AGENCY
}

model ChatMessage {
  id        String  @id @default(uuid())
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  senderName String         @map("sender_name")
  senderType ChatSenderType @map("sender_type")
  content    String

  sentAt       DateTime @map("sent_at")
  upworkRoomId String?  @map("upwork_room_id")

  syncedById String? @map("synced_by_id")
  syncedBy   User?   @relation("ChatSyncedBy", fields: [syncedById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([projectId, sentAt, senderName], map: "uq_chat_messages_dedup")
  @@index([projectId], map: "idx_chat_messages_project")
  @@map("chat_messages")
}

// -------------------------------------------------------
// Events (Universal Audit Log)
// -------------------------------------------------------

model Event {
  id         String @id @default(uuid())
  eventType  String @map("event_type")
  entityType String @map("entity_type")
  entityId   String @map("entity_id")

  actorId String? @map("actor_id")
  actor   User?   @relation("EventActor", fields: [actorId], references: [id])

  organizationId String? @map("organization_id")
  metadata       Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventType], map: "idx_events_type")
  @@index([entityType, entityId], map: "idx_events_entity")
  @@index([actorId], map: "idx_events_actor")
  @@index([organizationId], map: "idx_events_org")
  @@index([createdAt], map: "idx_events_created_at")
  @@map("events")
}

// -------------------------------------------------------
// Experiments (A/B Testing — Template/Script Performance)
// -------------------------------------------------------

enum ExperimentStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
}

model Experiment {
  id          String           @id @default(uuid())
  name        String
  description String?
  hypothesis  String?
  status      ExperimentStatus @default(DRAFT)

  targetEntity String @map("target_entity")
  variants     Json

  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")

  assignments ExperimentAssignment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("experiments")
}

model ExperimentAssignment {
  id           String     @id @default(uuid())
  experimentId String     @map("experiment_id")
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id])

  variant    String
  outcome    String?
  assignedAt DateTime @default(now()) @map("assigned_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([experimentId], map: "idx_experiment_assignments_experiment")
  @@index([projectId], map: "idx_experiment_assignments_project")
  @@map("experiment_assignments")
}
