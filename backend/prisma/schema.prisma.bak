// -------------------------------------------------------
// AOP Platform — Prisma Schema
// -------------------------------------------------------

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// -------------------------------------------------------
// Identity & Access
// -------------------------------------------------------

model Role {
  id   String @id @default(uuid())
  name String @unique

  users User[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model Team {
  id   String @id @default(uuid())
  name String

  users User[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("teams")
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String  @map("password_hash")
  firstName    String? @map("first_name")
  lastName     String? @map("last_name")
  isActive     Boolean @default(true) @map("is_active")

  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id])

  teamId String? @map("team_id")
  team   Team?   @relation(fields: [teamId], references: [id])

  agents          Agent[]
  closerNiches    CloserNiche[]
  closedProposals Proposal[]     @relation("ProposalCloser")
  scriptsCreated  Script[]       @relation("ScriptCreator")
  closedMeetings  Meeting[]      @relation("MeetingCloser")
  assignedTasks   Task[]         @relation("TaskAssignee")
  qaReviews       QAReview[]     @relation("QAReviewer")
  eventsActed     Event[]        @relation("EventActor")
  refreshTokens   RefreshToken[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([email], map: "idx_users_email")
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([token], map: "idx_refresh_tokens_token")
  @@map("refresh_tokens")
}

// -------------------------------------------------------
// Niches (Project Categories)
// -------------------------------------------------------

model Niche {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?
  isActive    Boolean @default(true) @map("is_active")

  closers   CloserNiche[]
  proposals Proposal[]
  scripts   Script[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("niches")
}

model CloserNiche {
  id      String @id @default(uuid())
  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  nicheId String @map("niche_id")
  niche   Niche  @relation(fields: [nicheId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, nicheId])
  @@map("closer_niches")
}

// -------------------------------------------------------
// Accounts & Agents
// -------------------------------------------------------

enum AccountPlatform {
  UPWORK
  FREELANCER
  TOPTAL
  OTHER
}

enum AccountStatus {
  ACTIVE
  PAUSED
  SUSPENDED
  CLOSED
}

model FreelanceAccount {
  id          String          @id @default(uuid())
  platform    AccountPlatform
  accountName String          @map("account_name")
  profileUrl  String?         @map("profile_url")
  status      AccountStatus   @default(ACTIVE)

  agents Agent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("freelance_accounts")
}

model Agent {
  id                 String           @id @default(uuid())
  userId             String           @map("user_id")
  user               User             @relation(fields: [userId], references: [id])
  freelanceAccountId String           @map("freelance_account_id")
  freelanceAccount   FreelanceAccount @relation(fields: [freelanceAccountId], references: [id])

  isActive Boolean @default(true) @map("is_active")

  proposals              Proposal[]
  experimentAssignments  ExperimentAssignment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, freelanceAccountId])
  @@map("agents")
}

// -------------------------------------------------------
// Clients
// -------------------------------------------------------

model Client {
  id              String  @id @default(uuid())
  marketplaceId   String? @map("marketplace_id")
  name            String
  company         String?
  platform        AccountPlatform?
  profileUrl      String? @map("profile_url")
  country         String?
  totalSpent      Float?  @map("total_spent")
  hireRate        Float?  @map("hire_rate")
  jobsPosted      Int?    @map("jobs_posted")

  proposals Proposal[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([marketplaceId], map: "idx_clients_marketplace_id")
  @@map("clients")
}

// -------------------------------------------------------
// Scripts & Versions
// -------------------------------------------------------

model Script {
  id        String @id @default(uuid())
  name      String
  category  String?

  createdById String @map("created_by_id")
  createdBy   User   @relation("ScriptCreator", fields: [createdById], references: [id])

  nicheId String? @map("niche_id")
  niche   Niche?  @relation(fields: [nicheId], references: [id])

  versions ScriptVersion[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("scripts")
}

model ScriptVersion {
  id       String @id @default(uuid())
  scriptId String @map("script_id")
  script   Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  content  String
  version  Int

  proposals Proposal[]

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([scriptId, version])
  @@map("script_versions")
}

// -------------------------------------------------------
// Proposals
// -------------------------------------------------------

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  REPLIED
  INTERVIEW
  HIRED
  REJECTED
  WITHDRAWN
}

model Proposal {
  id              String         @id @default(uuid())
  agentId         String         @map("agent_id")
  agent           Agent          @relation(fields: [agentId], references: [id])
  clientId        String         @map("client_id")
  client          Client         @relation(fields: [clientId], references: [id])
  scriptVersionId String?        @map("script_version_id")
  scriptVersion   ScriptVersion? @relation(fields: [scriptVersionId], references: [id])

  nicheId   String? @map("niche_id")
  niche     Niche?  @relation(fields: [nicheId], references: [id])
  closerId  String? @map("closer_id")
  closer    User?   @relation("ProposalCloser", fields: [closerId], references: [id])
  claimedAt DateTime? @map("claimed_at")

  jobTitle    String?        @map("job_title")
  jobUrl      String?        @map("job_url")
  coverLetter String?        @map("cover_letter")
  bidAmount   Float?         @map("bid_amount")
  notes       String?
  status      ProposalStatus @default(DRAFT)
  sentAt      DateTime?      @map("sent_at")
  replyAt     DateTime?      @map("reply_at")

  videoProposal VideoProposal?
  meeting       Meeting?
  deal          Deal?
  experimentAssignments ExperimentAssignment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([agentId], map: "idx_proposals_agent")
  @@index([status], map: "idx_proposals_status")
  @@index([clientId], map: "idx_proposals_client")
  @@index([nicheId], map: "idx_proposals_niche")
  @@index([closerId], map: "idx_proposals_closer")
  @@map("proposals")
}

// -------------------------------------------------------
// Video Proposals
// -------------------------------------------------------

model VideoProposal {
  id         String @id @default(uuid())
  proposalId String @unique @map("proposal_id")
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  videoUrl   String  @map("video_url")
  storageKey String  @map("storage_key")
  duration   Int? // seconds
  fileSize   Int? @map("file_size") // bytes
  mimeType   String? @map("mime_type")

  thumbnailUrl String? @map("thumbnail_url")
  viewCount    Int     @default(0) @map("view_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("video_proposals")
}

// -------------------------------------------------------
// Meetings
// -------------------------------------------------------

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Meeting {
  id         String @id @default(uuid())
  proposalId String @unique @map("proposal_id")
  proposal   Proposal @relation(fields: [proposalId], references: [id])

  closerId   String? @map("closer_id")
  closer     User?   @relation("MeetingCloser", fields: [closerId], references: [id])

  scheduledAt DateTime      @map("scheduled_at")
  completedAt DateTime?     @map("completed_at")
  status      MeetingStatus @default(SCHEDULED)
  notes       String?
  meetingUrl  String?       @map("meeting_url")
  duration    Int? // minutes

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("meetings")
}

// -------------------------------------------------------
// Deals
// -------------------------------------------------------

enum DealStatus {
  NEGOTIATING
  WON
  LOST
  CANCELLED
}

model Deal {
  id         String @id @default(uuid())
  proposalId String @unique @map("proposal_id")
  proposal   Proposal @relation(fields: [proposalId], references: [id])

  value    Float
  currency String     @default("USD")
  status   DealStatus @default(NEGOTIATING)
  closedAt DateTime?  @map("closed_at")
  notes    String?

  project Project?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status], map: "idx_deals_status")
  @@map("deals")
}

// -------------------------------------------------------
// Projects
// -------------------------------------------------------

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

model Project {
  id     String @id @default(uuid())
  dealId String @unique @map("deal_id")
  deal   Deal   @relation(fields: [dealId], references: [id])

  name      String?
  startDate DateTime?     @map("start_date")
  endDate   DateTime?     @map("end_date")
  status    ProjectStatus @default(NOT_STARTED)

  milestones Milestone[]
  tasks      Task[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("projects")
}

model Milestone {
  id        String @id @default(uuid())
  projectId String @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name      String
  dueDate   DateTime? @map("due_date")
  amount    Float?
  completed Boolean   @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("milestones")
}

// -------------------------------------------------------
// Tasks
// -------------------------------------------------------

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
}

model Task {
  id        String @id @default(uuid())
  projectId String @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId String? @map("assignee_id")
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Int        @default(0)
  estimatedHours Float?  @map("estimated_hours")
  completedAt DateTime?  @map("completed_at")

  qaReview QAReview?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId], map: "idx_tasks_project")
  @@index([assigneeId], map: "idx_tasks_assignee")
  @@index([status], map: "idx_tasks_status")
  @@map("tasks")
}

// -------------------------------------------------------
// QA Reviews
// -------------------------------------------------------

enum QAStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_CHANGES
}

model QAReview {
  id     String @id @default(uuid())
  taskId String @unique @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  reviewerId String @map("reviewer_id")
  reviewer   User   @relation("QAReviewer", fields: [reviewerId], references: [id])

  status   QAStatus @default(PENDING)
  score    Int?     // 1-10
  comments String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("qa_reviews")
}

// -------------------------------------------------------
// Events (Universal Event Tracking)
// -------------------------------------------------------

model Event {
  id         String @id @default(uuid())
  eventType  String @map("event_type")
  entityType String @map("entity_type")
  entityId   String @map("entity_id")

  actorId String? @map("actor_id")
  actor   User?   @relation("EventActor", fields: [actorId], references: [id])

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventType], map: "idx_events_type")
  @@index([entityType, entityId], map: "idx_events_entity")
  @@index([actorId], map: "idx_events_actor")
  @@index([createdAt], map: "idx_events_created_at")
  @@map("events")
}

// -------------------------------------------------------
// Experiments (A/B Testing)
// -------------------------------------------------------

enum ExperimentStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
}

model Experiment {
  id          String           @id @default(uuid())
  name        String
  description String?
  hypothesis  String?
  status      ExperimentStatus @default(DRAFT)

  targetEntity String @map("target_entity") // e.g., "script", "video_style"
  variants     Json   // JSON array of variant definitions

  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")

  assignments ExperimentAssignment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("experiments")
}

model ExperimentAssignment {
  id           String     @id @default(uuid())
  experimentId String     @map("experiment_id")
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  agentId    String?   @map("agent_id")
  agent      Agent?    @relation(fields: [agentId], references: [id])
  proposalId String?   @map("proposal_id")
  proposal   Proposal? @relation(fields: [proposalId], references: [id])

  variant  String
  assignedAt DateTime @default(now()) @map("assigned_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([experimentId], map: "idx_experiment_assignments_experiment")
  @@index([agentId], map: "idx_experiment_assignments_agent")
  @@map("experiment_assignments")
}

// -------------------------------------------------------
// Analytics (Materialized KPI Tables)
// -------------------------------------------------------

model DailyAgentMetric {
  id      String   @id @default(uuid())
  agentId String   @map("agent_id")
  date    DateTime @db.Date

  proposalsSent    Int @default(0) @map("proposals_sent")
  proposalsViewed  Int @default(0) @map("proposals_viewed")
  proposalsReplied Int @default(0) @map("proposals_replied")
  meetingsBooked   Int @default(0) @map("meetings_booked")
  dealsClosed      Int @default(0) @map("deals_closed")
  totalDealValue   Float @default(0) @map("total_deal_value")
  videosRecorded   Int @default(0) @map("videos_recorded")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([agentId, date])
  @@index([agentId], map: "idx_daily_agent_metrics_agent")
  @@index([date], map: "idx_daily_agent_metrics_date")
  @@map("daily_agent_metrics")
}

model DailyAccountMetric {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  date      DateTime @db.Date

  proposalsSent    Int @default(0) @map("proposals_sent")
  proposalsViewed  Int @default(0) @map("proposals_viewed")
  proposalsReplied Int @default(0) @map("proposals_replied")
  meetingsBooked   Int @default(0) @map("meetings_booked")
  dealsClosed      Int @default(0) @map("deals_closed")
  totalDealValue   Float @default(0) @map("total_deal_value")
  conversionRate   Float @default(0) @map("conversion_rate")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([accountId, date])
  @@index([accountId], map: "idx_daily_account_metrics_account")
  @@index([date], map: "idx_daily_account_metrics_date")
  @@map("daily_account_metrics")
}
